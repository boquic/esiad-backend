# Plantilla de entorno para docker-compose.test.yml
# Copia a .env.test y ajusta si hace falta. NO subas .env.test al repo.

NODE_ENV=test
PORT=3000

# DB efímera de tests (servicio postgres-test).
DATABASE_URL=postgresql://postgres:postgres@postgres-test:5432/sigeped_test

POSTGRES_DB=sigeped_test
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# JWT de pruebas
JWT_SECRET=test-secret
JWT_EXPIRES_IN=24h

FRONTEND_URL=http://localhost:4200

UPLOAD_MAX_SIZE_MB=20
UPLOAD_PATH=/tmp/uploads

# Twilio vacío para no enviar mensajes reales durante los tests.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
NGROK_URL=
