# Base de datos
DATABASE_URL="postgresql://postgres:admin@127.0.0.1:5433/sigeped"
# En Docker Compose, usa el nombre del servicio PostgreSQL en lugar de 127.0.0.1:
# DATABASE_URL="postgresql://postgres:admin@postgres:5432/sigeped"

# Servidor
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:4200

# JWT
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=24h

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
NGROK_URL=https://your-ngrok-subdomain.ngrok-free.app

# Archivos
UPLOAD_MAX_SIZE_MB=20
UPLOAD_PATH=./uploads
# En Docker Compose, monta un volumen persistente y usa una ruta absoluta:
# UPLOAD_PATH=/app/uploads
